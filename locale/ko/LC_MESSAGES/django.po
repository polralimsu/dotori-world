msgid "Email"
msgstr "이메일"

msgid "Please check your email to activate your account."
msgstr "계정을 활성화하려면 이메일을 확인해주세요."

msgid "Your account has been activated."
msgstr "계정이 활성화되었습니다."

msgid "Activation link is invalid!"
msgstr "활성화 링크가 유효하지 않습니다!"

msgid "DOTORi World - Verify your email"
msgstr "DOTORi World - 이메일 인증"

msgid "Hello"
msgstr "안녕하세요"

msgid "Thank you for signing up for DOTORi World."
msgstr "DOTORi World에 가입해주셔서 감사합니다."

msgid "Please click the link below to activate your account:"
msgstr "아래 링크를 클릭하여 계정을 활성화하세요:"

msgid "If you did not sign up, please ignore this email."
msgstr "가입하지 않으셨다면 이 이메일을 무시해주세요."

msgid "Thank you,"
msgstr "감사합니다,"

msgid "Find Username"
msgstr "아이디 찾기"

msgid "Enter your email address to find your username."
msgstr "아이디를 찾으려면 이메일 주소를 입력하세요."

msgid "Your username is: %(username)s"
msgstr "회원님의 아이디는: %(username)s"

msgid "No account found with that email address."
msgstr "해당 이메일로 등록된 계정이 없습니다."

msgid "Back to login"
msgstr "로그인으로 돌아가기"

msgid "Password Reset"
msgstr "비밀번호 재설정"

msgid "Reset Password"
msgstr "비밀번호 찾기"

msgid ""
"Enter your email address and we will send you a link to reset your password."
msgstr "이메일 주소를 입력하면 비밀번호 재설정 링크를 보내드립니다."

msgid "Send Reset Link"
msgstr "재설정 링크 보내기"

msgid ""
"A password reset link has been sent to your email address. Please check your"
" inbox."
msgstr "비밀번호 재설정 링크가 이메일로 발송되었습니다. 받은 편지함을 확인해주세요."

msgid "Set New Password"
msgstr "새 비밀번호 설정"

msgid "Change Password"
msgstr "비밀번호 변경"

msgid ""
"This password reset link is invalid or has expired. Please request a new "
"one."
msgstr "이 비밀번호 재설정 링크는 유효하지 않거나 만료되었습니다. 새로 요청해주세요."

msgid "Request new link"
msgstr "새 링크 요청"

msgid "Password Reset Complete"
msgstr "비밀번호 재설정 완료"

msgid ""
"Your password has been successfully changed. You can now log in with your "
"new password."
msgstr "비밀번호가 성공적으로 변경되었습니다. 새 비밀번호로 로그인할 수 있습니다."

msgid ""
"You are receiving this email because a password reset was requested for your"
" DOTORi World account."
msgstr "DOTORi World 계정의 비밀번호 재설정이 요청되어 이 이메일을 보내드립니다."

msgid "Please click the link below to set a new password:"
msgstr "아래 링크를 클릭하여 새 비밀번호를 설정하세요:"

msgid "If you did not request a password reset, please ignore this email."
msgstr "비밀번호 재설정을 요청하지 않으셨다면 이 이메일을 무시해주세요."
