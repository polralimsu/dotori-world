# Django Security Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*
# Comma-separated list of trusted origins for CSRF verification behind ALB
# Example: https://yourdomain.com,https://*.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://*.yourdomain.com

# Database Settings (dj-database-url format)
# Example for MySQL: mysql://user:password@host:port/dbname
DATABASE_URL=mysql://root:1234@127.0.0.1:3306/dotori_db

# Amazon S3 / CloudFront Settings (for Media & Static Files)
#AWS_ACCESS_KEY_ID=your-aws-access-key
#AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=ap-northeast-2
AWS_S3_CUSTOM_DOMAIN=d123456789.cloudfront.net  # Optional: Use CloudFront domain if configured

# Amazon Translate Settings (boto3 uses default credentials by default, but you can explicitly specify them)
# AWS_DEFAULT_REGION=ap-northeast-2

# Email Configuration
# Backend options:
#   Development (console):    django.core.mail.backends.console.EmailBackend
#   SMTP:                     django.core.mail.backends.smtp.EmailBackend
#   Amazon SES (API):         django_ses.SESBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com

# SMTP settings (when EMAIL_BACKEND = django.core.mail.backends.smtp.EmailBackend)
# Also works for Amazon SES SMTP interface
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Amazon SES API settings (when EMAIL_BACKEND = django_ses.SESBackend)
AWS_SES_REGION_NAME=ap-northeast-2
